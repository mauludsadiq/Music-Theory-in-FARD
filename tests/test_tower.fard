import("std/list") as list
import("../src/tower") as tower
import("../src/layers/note") as note
import("../src/layers/interval") as interval
import("../src/layers/chord") as chord
import("../src/layers/scale") as scale
import("../src/layers/rhythm") as rhythm
import("../src/layers/melody") as melody
import("../src/layers/progression") as progression
import("../src/layers/piece") as piece
import("../src/core/validate") as v

test "note C4 validates and certifies" {
  let c4 = note.make("C", 4, 0.0, "12-TET-A440")
  v.is_ok(note.validate(c4)) && c4.midi_note == 60 && note.digest(c4) == note.certify(c4).object_digest
}

test "interval C4 to G4 is perfect fifth" {
  let c4 = note.make("C", 4, 0.0, "12-TET-A440")
  let g4 = note.make("G", 4, 0.0, "12-TET-A440")
  let iv = interval.make(c4, g4)
  v.is_ok(interval.validate(iv)) && iv.simple_semitones == 7 && iv.quality == "Perfect Fifth"
}

test "major chord validates" {
  let c4 = note.make("C", 4, 0.0, "12-TET-A440")
  let ch = chord.make(c4, "Major", 0, "close")
  v.is_ok(chord.validate(ch)) && list.len(ch.note_digests) == 3
}

test "major scale spans octave" {
  let c4 = note.make("C", 4, 0.0, "12-TET-A440")
  let sc = scale.make(c4, "Major", "Western")
  v.is_ok(scale.validate(sc)) && sc.cardinality == 7 && sc.leading_tone == true
}

test "rhythm validates" {
  let q = rhythm.duration("quarter", 1, 4, 0)
  let m = rhythm.meter(4, 4, [1,1,1,1])
  let r = rhythm.pattern("four quarters", m, [rhythm.event("note", q, 0), rhythm.event("note", q, 1), rhythm.event("note", q, 2), rhythm.event("note", q, 3)])
  v.is_ok(rhythm.validate(r)) && r.length == 4
}

test "melody validates with contour" {
  let c4 = note.make("C", 4, 0.0, "12-TET-A440")
  let d4 = note.make("D", 4, 0.0, "12-TET-A440")
  let e4 = note.make("E", 4, 0.0, "12-TET-A440")
  let q = rhythm.duration("quarter", 1, 4, 0)
  let r = rhythm.pattern("three", rhythm.meter(3, 4, [1,1,1]), [rhythm.event("note", q, 0), rhythm.event("note", q, 1), rhythm.event("note", q, 2)])
  let sc = scale.make(c4, "Major", "Western")
  let m = melody.make("ascending", [c4,d4,e4], [q,q,q], sc, r, null)
  v.is_ok(melody.validate(m)) && m.contour == ["up", "up"]
}

test "progression and piece validate" {
  let c4 = note.make("C", 4, 0.0, "12-TET-A440")
  let f4 = note.make("F", 4, 0.0, "12-TET-A440")
  let g4 = note.make("G", 4, 0.0, "12-TET-A440")
  let q = rhythm.duration("quarter", 1, 4, 0)
  let r = rhythm.pattern("common", rhythm.meter(4, 4, [1,1,1,1]), [rhythm.event("note", q, 0), rhythm.event("note", q, 1), rhythm.event("note", q, 2), rhythm.event("note", q, 3)])
  let sc = scale.make(c4, "Major", "Western")
  let mel = melody.make("cell", [c4,g4,c4], [q,q,q], sc, r, null)
  let I = chord.make(c4, "Major", 0, "close")
  let IV = chord.make(f4, "Major", 0, "close")
  let V = chord.make(g4, "Major", 0, "close")
  let prog = progression.make("I IV V I", sc, [progression.state("I", I, 1), progression.state("IV", IV, 1), progression.state("V", V, 1), progression.state("I", I, 1)], mel)
  let pc = piece.make("Certified Miniature", "period", "homophonic", "didactic", "contemporary", ["piano"], [mel], [prog], [r], ["A"])
  v.is_ok(progression.validate(prog)) && v.is_ok(piece.validate(pc)) && tower.verify_tower()
}

tower.tower_digest()
