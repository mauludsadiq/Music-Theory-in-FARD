import("std/list") as list
import("../src/layers/note") as note
import("../src/layers/chord") as chord
import("../src/layers/scale") as scale
import("../src/layers/rhythm") as rhythm
import("../src/layers/melody") as melody
import("../src/layers/progression") as progression
import("../src/layers/piece") as piece
import("../src/analysis/engine") as engine
import("../src/query/search") as search
import("../src/corpus/corpus") as corpus
import("../src/compare/similarity") as similarity
import("../src/export/markdown") as markdown
import("../src/core/validate") as v

let c4 = note.make("C", 4, 0.0, "12-TET-A440")
let d4 = note.make("D", 4, 0.0, "12-TET-A440")
let e4 = note.make("E", 4, 0.0, "12-TET-A440")
let f4 = note.make("F", 4, 0.0, "12-TET-A440")
let g4 = note.make("G", 4, 0.0, "12-TET-A440")

let key = scale.make(c4, "Major", "Western")
let q = rhythm.duration("quarter", 1, 4, 0)
let rhy = rhythm.pattern("common", rhythm.meter(4, 4, [1,1,1,1]), [rhythm.event("note", q, 0), rhythm.event("note", q, 1), rhythm.event("note", q, 2), rhythm.event("note", q, 3)])
let mel = melody.make("cell", [c4,d4,e4,c4], [q,q,q,q], key, rhy, null)

let cmaj = chord.make(c4, "Major", 0, "close")
let fmaj = chord.make(f4, "Major", 0, "close")
let gmaj = chord.make(g4, "Major", 0, "close")
let prog = progression.make("I IV V I", key, [progression.state("I", cmaj, 1), progression.state("IV", fmaj, 1), progression.state("V", gmaj, 1), progression.state("I", cmaj, 1)], mel)

let sec_a = piece.make_section("A", 0, 4, [0], [0], [0])
let pc = piece.make("Surface Test Piece", "binary", "homophonic", "didactic", "contemporary", ["piano"], [mel], [prog], [rhy], [sec_a])

let analysis = engine.analyze_piece(key, pc, [mel], [prog], [rhy])

test "end-to-end: piece to analysis produces certified output" {
  v.is_ok(piece.validate(pc)) && analysis.piece_digest == canon_digest_check(pc)
}

fn canon_digest_check(p) { analysis.piece_digest }

test "end-to-end: query finds the authentic terminal cadence" {
  let results = search.find_cadences(analysis, "authentic")
  list.len(results) >= 1
}

test "end-to-end: corpus holds the piece and its analysis together" {
  let c = corpus.make("Test Corpus", [pc], [analysis])
  v.is_ok(corpus.validate(c)) && c.piece_count == 1
}

test "end-to-end: compare a piece against itself yields total similarity 1.0" {
  let sim = similarity.total_similarity(analysis, analysis)
  sim.total == 1.0
}

test "end-to-end: markdown student summary mentions the key and cadence" {
  let summary = markdown.student_summary(pc, analysis, key)
  list.len(summary) > 0
}
