import("std/list") as list
import("../corpus/bach_minuet_g") as bach
import("../src/layers/piece") as piece
import("../src/analysis/engine") as engine
import("../src/query/search") as search
import("../src/core/validate") as v

test "bach minuet piece validates" {
  v.is_ok(piece.validate(bach.pc))
}

test "bach minuet has a repeated motive (G-B-A opening cell recurs)" {
  let analysis = engine.analyze_piece(bach.key, bach.pc, [bach.phrase_a, bach.phrase_b], [bach.prog], [])
  list.len(analysis.motives.repeated) >= 1
}

test "bach minuet form is A B" {
  bach.pc.sections[0].label == "A" && bach.pc.sections[1].label == "B"
}
