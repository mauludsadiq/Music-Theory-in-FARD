import("std/list") as list
import("../corpus/amazing_grace") as grace
import("../src/layers/piece") as piece
import("../src/analysis/engine") as engine
import("../src/query/search") as search
import("../src/core/validate") as v

test "amazing grace piece validates" {
  v.is_ok(piece.validate(grace.pc))
}

test "amazing grace ends on a plagal cadence" {
  let analysis = engine.analyze_piece(grace.key, grace.pc, [grace.phrase_a, grace.phrase_b], [grace.prog], [])
  let terminal = search.find_terminal_cadences(analysis, "plagal")
  list.len(terminal) >= 1
}

test "amazing grace has a repeated D-G-B opening motive across both phrases" {
  let analysis = engine.analyze_piece(grace.key, grace.pc, [grace.phrase_a, grace.phrase_b], [grace.prog], [])
  list.len(analysis.motives.repeated) >= 1
}

test "amazing grace form is A B" {
  grace.pc.sections[0].label == "A" && grace.pc.sections[1].label == "B"
}
